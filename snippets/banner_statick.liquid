        <div class="banner_statick">
          <div class="image_static ">
            <div class="image_1 images-card  ">
            {% assign image_1 = section.settings.image_1 %}
            {% assign link_1 = section.settings.link_img_1 | default:'#' %}
            {% if image_1 != blank %}
              {% render 'responsive-image', image: image_1, image_class: 'w-full h-full', url: link_1 %}
            {% else %}
              <div class="image-card__img h-full">
                {{ 'hero-apparel-1' | placeholder_svg_tag: 'placeholder-svg' }}
              </div>
            {% endif %}
            {% if section.settings.content_1 != blank %}
              <div class="content-img">
                {{ section.settings.content_1 }}
              </div>
            {% endif %}
            </div>
